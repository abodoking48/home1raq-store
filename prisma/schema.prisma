generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id             String      @id @default(cuid())
  name           String
  slug           String      @unique
  description    String      @db.Text
  price          Decimal     @db.Decimal(12, 2)
  /// Optional strikethrough "was" price for promo display
  compareAtPrice Decimal?    @db.Decimal(12, 2)
  /// Shown on /products?promo=1 when true
  onPromo        Boolean     @default(false)
  images         String[]
  active         Boolean     @default(true)
  categoryId     String?
  category       Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  orderItems     OrderItem[]
  landingLines   LandingPageProduct[]

  @@index([active])
  @@index([slug])
  @@index([categoryId])
  @@index([active, onPromo])
}

/// Campaign landing at `/landing/[slug]` — admin-controlled; single or multi-product slider.
model LandingPage {
  id               String           @id @default(cuid())
  title            String           @default("")
  slug             String           @unique
  enabled          Boolean          @default(true)
  mode             LandingPageMode  @default(SLIDER)
  /// First visible slide index (0-based); clamped on read for public payload.
  defaultProductIndex Int           @default(0)
  /// Auto-advance slides on public landing (multi-product slider only).
  sliderAutoPlay      Boolean       @default(false)
  /// Seconds between auto slides (typically 4–5).
  sliderAutoPlayIntervalSec Int     @default(5)
  countdownHours   Int              @default(48)
  whatsappOverride String?
  benefitsJson     Json
  reviewsJson      Json
  offerBadge       String           @default("")
  offerTitle       String           @default("")
  offerTitleAccent String           @default("")
  offerSubtitle    String           @default("")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  products         LandingPageProduct[]

  @@index([enabled, slug])
}

enum LandingPageMode {
  SINGLE
  SLIDER
}

/// Product on a landing with per-campaign overrides (same SKU, different price/copy per page).
model LandingPageProduct {
  id                String      @id @default(cuid())
  landingPageId     String
  landingPage       LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)
  productId         String
  product           Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  displayOrder      Int         @default(0)
  titleOverride     String?
  customDescription String?     @db.Text
  imagesOverride    String[]    @default([])
  videoUrl          String?
  customPrice       Decimal?    @db.Decimal(12, 2)
  customCompareAt   Decimal?    @db.Decimal(12, 2)
  onPromoOverride   Boolean?
  /// Optional 1–5 stars shown on landing for this line (campaign-specific).
  displayRating       Int?

  @@unique([landingPageId, productId])
  @@index([landingPageId, displayOrder])
  @@index([productId])
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  icon        String    @default("kitchen")
  iconUrl     String?
  description String?   @db.Text
  active      Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@index([active, sortOrder])
  @@index([slug])
}

model Order {
  id        String      @id @default(cuid())
  fullName  String
  phone     String
  address   String      @db.Text
  city      String
  notes     String?
  total     Decimal     @db.Decimal(12, 2)
  status    OrderStatus @default(PENDING)
  createdAt DateTime    @default(now())
  items     OrderItem[]
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  quantity     Int
  priceAtOrder Decimal  @db.Decimal(12, 2)

  @@index([orderId])
  @@index([productId])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
}
